# ═══════════════════════════════════════════════════════════════
# AI Agent Company — Environment Variables
# Copy this file: cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ── Required ──────────────────────────────────────────────────

# Supabase project URL (Settings → API → Project URL)
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/publishable key (Settings → API → anon public)
SUPABASE_ANON_KEY=eyJhbGci...

# PostgreSQL connection string (Settings → Database → Connection string → URI)
# Use the "Transaction mode" pooler URI. URL-encode any @ in the password as %40.
DATABASE_URL=postgresql://postgres.xxx:password@aws-1-region.pooler.supabase.com:6543/postgres

# Anthropic API key OR Claude subscription (only one needed)
# If using Claude subscription: skip this, run `claude /login` inside the container
# If using API key: get one at https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Telegram Bots ─────────────────────────────────────────────
# Create 10 bots via @BotFather on Telegram, one per agent role.

TELEGRAM_GROUP_ID="-100xxxxxxxxxx"
OWNER_TELEGRAM_ID="YOUR_TELEGRAM_ID"

BOT_ORCHESTRATOR="YOUR_BOT_TOKEN"
BOT_ARCHITECT="YOUR_BOT_TOKEN"
BOT_DESIGN="YOUR_BOT_TOKEN"
BOT_FRONTEND="YOUR_BOT_TOKEN"
BOT_BACKEND="YOUR_BOT_TOKEN"
BOT_SMARTCONTRACT="YOUR_BOT_TOKEN"
BOT_RESEARCHER="YOUR_BOT_TOKEN"
BOT_TESTER="YOUR_BOT_TOKEN"
BOT_SECURITY="YOUR_BOT_TOKEN"
BOT_DEVOPS="YOUR_BOT_TOKEN"

# ── Agent Configuration ──────────────────────────────────────

# Max agents running simultaneously (tune for your RAM)
MAX_WORK_AGENTS=3

# Task timeout in seconds
AGENT_TIMEOUT_SECONDS=3600

# ── Optional — PixelCompany Marketplace ──────────────────────
# Connect to https://pixelcompany.fun to import marketplace agents.
# Leave blank to run fully standalone with local SKILL.md files.

# Platform URL (default: https://pixelcompany.fun)
# PLATFORM_URL=https://pixelcompany.fun

# Your API key from pixelcompany.fun/settings
# PLATFORM_API_KEY=
